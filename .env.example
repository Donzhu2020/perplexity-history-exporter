# Auth persistence
AUTH_STORAGE_PATH=.storage/auth.json

# Scraping behavior
WAIT_MODE=static
RATE_LIMIT_MS=3000
PARALLEL_WORKERS=2
CHECKPOINT_SAVE_INTERVAL=10

# Vector search
ENABLE_VECTOR_SEARCH=true

# AI services
# AI_PROVIDER is a legacy shortcut. Prefer EMBED_PROVIDER and GENERATE_PROVIDER.
AI_PROVIDER=huggingface
EMBED_PROVIDER=huggingface
GENERATE_PROVIDER=lmstudio
GEMINI_API_KEY=
GEMINI_API_URL=https://generativelanguage.googleapis.com/v1beta
GEMINI_MODEL=gemini-2.0-flash
GEMINI_EMBED_MODEL=gemini-embedding-001
HF_TOKEN=
HF_API_URL=https://router.huggingface.co/hf-inference/models
HF_ROUTER_URL=https://router.huggingface.co/v1
HF_MODEL=Qwen/Qwen2.5-7B-Instruct:hf-inference
HF_EMBED_MODEL=intfloat/multilingual-e5-large
LM_STUDIO_BASE_URL=http://127.0.0.1:1234/v1
LM_STUDIO_MODEL=your-loaded-model-name
LM_STUDIO_API_KEY=
OLLAMA_URL=http://localhost:11434
OLLAMA_MODEL=deepseek-r1
OLLAMA_EMBED_MODEL=nomic-embed-text

# Paths
EXPORT_DIR=exports
CHECKPOINT_PATH=.storage/checkpoint.json
VECTOR_INDEX_PATH=.storage/vector-index

# Browser behavior
# HEADLESS can be 'true', 'false', or 'new'
HEADLESS=true
